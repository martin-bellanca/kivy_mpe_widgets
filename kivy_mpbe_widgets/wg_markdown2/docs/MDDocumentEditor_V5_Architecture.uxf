*LineState*
--
*Referencia a datos*
+md_line: MDLine  // referencia, no copia
+index: int
--
*Estado de UI*
+selected: bool = False
+active: bool = False
+editing: bool = False
+hotlight: bool = False
+cursor_pos: Tuple[int, int] = (0, 0)
--
*Visibilidad y Grupos*
+visible: bool = True
+matched_search: bool = False
+group: str = 'visible'  # 'visible', 'hidden', 'filtered'
--
*Geometría*
+height: float = 30.0
+y_position: float = 0.0
--
*Animación y tema*
+anim_type: str = 'fade'  # Hace Falta??? 'fade' | 'slide_up' | 'slide_down' | 'expand_up' | 'expand_down'
+alpha_background: float = 0.0
--
*Sib-widgets*
+show_number_line: bool = True
+show_tree: bool = False
+show_infobar: bool = False
--
--
*Métodos*
+with_changes(**kwargs): LineState
+get_md_text(): str  // delegado a md_line
+get_line_type(): MD_LINE_TYPE  // delegado
--
*Evento (emitido al cambiar)*
+on_state_changed: EventDispatcher</panel_attributes>
