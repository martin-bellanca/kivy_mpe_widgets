*DocumentOperations*
--
+state_manager: DocumentStateManager
--
*Líneas - Activación*
+activate_line(index, enter_edit, cursor_pos): bool
+deactivate_current(): bool
+toggle_edit_mode(): bool
--
*Líneas - CRUD*
+insert_line_below(index, text): int
+insert_line_above(index, text): int
+delete_line(index): bool
+delete_selected_lines(): int
--
*Líneas - Movimiento*
+move_line_up(index): bool
+move_line_down(index): bool
+move_selected_up(): bool
+move_selected_down(): bool
--
*Navegación*
+navigate_next(): Optional[int]
+navigate_previous(): Optional[int]
+navigate_to_next_title(): Optional[int]
+navigate_to_parent_title(): Optional[int]
--
*Selección*
+select_line(index, multi): bool
+select_range(start, end): int
+select_all(): int
+clear_selection(): int
--
*Hotlight*
+set_hotlight(index, value: bool)
--
*Filtrado*
+filter_by_text(text, include_parents): int
+clear_filter(): int
--
*Texto*
+update_line_text(index, text): bool
--
*Consultas*
+is_line_editable(index): bool
+can_delete_line(index): bool</panel_attributes>
