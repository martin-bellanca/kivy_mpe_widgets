*DocumentStateManager*
*&lt;&lt;EventDispatcher&gt;&gt;*
*(ÚNICA FUENTE DE VERDAD)*
--
*Referencias*
+md_document: MDDocument  // ref externa
-_line_states: Dict[int, LineState]
-_active_index: Optional[int]
-_selected_indices: Set[int]
-_visible_indices: Set[int]
-_filtered_indices: Set[int]
--
*Inicialización*
+set_document(md_document: MDDocument)
+load_document(md_lines: List[MDLine])
+clear_all()
--
*Acceso a Estados*
+get_state(index): LineState
+get_md_line(index): MDLine
+get_active_index(): Optional[int]
+get_selected_indices(): Set[int]
+get_total_lines(): int
+get_visible_lines_count(): int
--
*Modificación de Estados (muta LineState)*
+update_state(index, **changes)
+activate_line(index, enter_edit, cursor_pos)
+deactivate_line(index)
+select_line(index, multi)
+select_range(start, end)
+clear_selection()
+toggle_selection(index)
+set_hotlight(index, value)
+set_visibility(index, visible)
+update_line_height(index, height)
--
*Operaciones de Documento (dispatch eventos)*
+insert_line(index, md_line): LineState
+remove_line(index)
+move_line(from_index, to_index)
+update_line_text(index, text)
--
*Geometría*
-_recalculate_geometry()
+get_visible_in_viewport(scroll_y, height): List[int]
--
*Eventos Estructurales (register_event_type)*
on_line_added(event: LineStateEvent)
on_line_removed(event: LineStateEvent)
on_line_moved(event: LineStateEvent)</panel_attributes>
