*LineState*
*&lt;&lt;EventDispatcher&gt;&gt;*
--
*Referencia a datos (ObjectProperty)*
+md_line: ObjectProperty(MDLine)
+index: NumericProperty(int)
--
*Estado de UI (BooleanProperty)*
+selected: BooleanProperty = False
+active: BooleanProperty = False
+editing: BooleanProperty = False
+hotlight: BooleanProperty = False
--
*Cursor (NumericProperty)*
+cursor_col: NumericProperty = 0
+cursor_row: NumericProperty = 0
+cursor_pos: property  // (col, row) computed
--
*Visibilidad (BooleanProperty/OptionProperty)*
+visible: BooleanProperty = True
+matched_search: BooleanProperty = False
+group: OptionProperty  // LineGroup.value
--
*Geometría (NumericProperty)*
+height: NumericProperty = 30.0
+y_position: NumericProperty = 0.0
--
*Animación y tema*
+anim_type: OptionProperty  // AnimationType.value
+alpha_background: NumericProperty = 0.0
--
*Sub-widgets (BooleanProperty)*
+show_number_line: BooleanProperty = True
+show_tree: BooleanProperty = False
+show_infobar: BooleanProperty = False
--
*Métodos Delegados*
+get_md_text(): str  // → md_line.md_text
+get_line_type(): MD_LINE_TYPE  // → md_line.type
--
*Helpers para Enums*
+get_group_enum(): LineGroup
+set_group_enum(LineGroup)
+get_anim_enum(): AnimationType
+set_anim_enum(AnimationType)
--
*EVENTOS AUTOMÁTICOS*
on_&lt;property&gt;  // Disparados por Kivy Properties</panel_attributes>
