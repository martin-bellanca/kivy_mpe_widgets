*MDDocumentEditor*
&lt;&lt;FocusBehavior, ThemableBehavior, ScrollView&gt;&gt;
--
*Referencias*
+state_manager: DocumentStateManager
+operations: DocumentOperations
-_line_widgets: Dict[int, MDDocumentLineEditor]
--
*Layout*
+content_layout: BoxLayout  // contiene los widgets
--
*Teclado (detecta y envía a operations)*
-_on_key_down(key, modifiers)
-_handle_arrow_up(modifiers)
-_handle_arrow_down(modifiers)
-_handle_enter(modifiers)
-_handle_delete()
-_handle_backspace()
-_handle_tab(modifiers)
-_handle_escape()
--
*Gestión de Widgets*
+create_line_widgets()
+add_line_widget(index): MDDocumentLineEditor
+remove_line_widget(index)
+scroll_to_index(index)
--
*Bindings a StateManager (eventos estructurales)*
_bind_to_state_manager():
    sm.bind(on_line_added=self._on_line_added)
    sm.bind(on_line_removed=self._on_line_removed)
    sm.bind(on_line_moved=self._on_line_moved)
--
*Callbacks de Eventos Estructurales*
-_on_line_added(instance, event: LineStateEvent)
-_on_line_removed(instance, event: LineStateEvent)
-_on_line_moved(instance, event: LineStateEvent)
--
*API Pública*
+load_document(md_document: MDDocument)
+get_widget_at_index(index): MDDocumentLineEditor</panel_attributes>
