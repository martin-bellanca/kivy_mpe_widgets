*LineStateEvent*
*@dataclass*
--
+index: int
+line_state: LineState
+event_type: EventType  // CHANGED, ADDED, REMOVED, MOVED
+changed_attributes: Set[str] = field(default_factory=set)
--
+is_structural_change(): bool  // ADDED, REMOVED, MOVED
+is_state_change(): bool  // CHANGED</panel_attributes>
